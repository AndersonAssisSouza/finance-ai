# Copie este arquivo para `.env` e preencha com seus valores reais.
# O arquivo `.env` esta no .gitignore — NUNCA commite credenciais.

DATABASE_URL=sqlite:///./finance.db

# Segredo usado para assinar tokens JWT. Gere um valor aleatorio forte.
# Ex: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-este-valor-em-producao

# Pluggy (opcional — para conciliacao bancaria via backend).
# Obtenha em https://dashboard.pluggy.ai/applications
# O frontend tambem aceita essas credenciais direto no localStorage (Conciliar > Pluggy direto)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
